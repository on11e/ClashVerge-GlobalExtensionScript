      "91.108.0.0/16", "149.154.160.0/20", "2001:b28:f23d::/48", "2001:67c:4e8::/48", "2001:b28:f23f::/48"
    ],
    processNames: []
  }
];

// 3. 🏠 直连白名单 (完整版 - 防止国内 App 变慢)
const DirectList = [
  "servicewechat.com", "qpic.cn", "qlogo.cn", "gtimg.com", "idqqimg.com", "cdn-go.cn", "wechatos.net", "weixinbridge.com",
  "bit.cn", "bit.edu.cn", "bitzh.edu.cn",
  "baidu.com", "sogou.com", "so.com", "cn.bing.com",
  "163.com", "126.net", "sina.com.cn", "sohu.com", "qq.com",
  "taobao.com", "tmall.com", "jd.com", "pinduoduo.com",
  "alipay.com", "meituan.com", "dianping.com", "suning.com",
  "bilibili.com", "iqiyi.com", "youku.com", "mgtv.com", "douyin.com", "kuaishou.com", "yy.com", "huya.com", "douyu.com",
  "weibo.com", "weibo.cn", "zhihu.com", "xiaohongshu.com", "tieba.baidu.com", "wechat.com", "weixin.com",
  "aliyun.com", "tencent.com", "huawei.com", "mi.com", "vivo.com", "oppo.com",
  "360.cn", "360safe.com", "chinaz.com", "csdn.net", "apple.com.cn", "icloud.com.cn", "dbankcdn.com"
];

// ================= 核心逻辑 (Core Logic) =================
const main = (config) => {
  try {
    // === 0. 环境检测 ===
    const engine = config?.meta?.engine?.toLowerCase() || "";
    const IS_CLASH_META = engine.includes("meta") || engine.includes("mihomo") || engine.includes("stash");

    // === 1. 提取并清洗节点 ===
    const rawProxies = (config.proxies || []).map(p => {
      if (!p) return null;
      if (typeof p === 'string') return p;
      return p.name || p.ps || p.id || null;
    }).filter(Boolean);

    const allValidProxies = [...new Set(rawProxies.filter(name => typeof name === 'string' && name.trim() !== "" && !BlockWords.test(name)))];

    if (allValidProxies.length === 0) {
      console.log("⚠️ 未找到有效节点，脚本跳过执行");
      return config;
    }

    // 全局兜底节点池 (同样限制数量以防万一)
    const performanceSafeProxies = allValidProxies.slice(0, MAX_PEERS);

    const newProxyGroups = [];
    const createdGroupNames = new Set(); 

    // === 核心组件 1: 全局自动兜底 (Layer 0) ===
    const globalFallbackName = "🚀 全局自动";
    newProxyGroups.push({
      name: globalFallbackName,
      type: "url-test",
      url: "http://www.gstatic.com/generate_204",
      interval: 86400, // 极低频测速，仅作兜底
      tolerance: 150,
      lazy: true,      // 省电核心
      proxies: performanceSafeProxies
    });
    createdGroupNames.add(globalFallbackName);

    // === 核心组件 2: 扁平化稳定架构 (修复版) ===
    const createAdvancedGroup = (groupName, icon, proxiesList) => {
      // 截断该组的节点数，保留手机端性能优势
      const safeProxiesList = proxiesList.slice(0, MAX_PEERS);
      const targetProxies = safeProxiesList.length > 0 ? safeProxiesList : performanceSafeProxies;
      
      // Layer 1. 核心自动组 (直接使用 url-test)
      const autoFailoverName = `⚙️ ${groupName}-自动`;
      newProxyGroups.push({
        name: autoFailoverName,
        type: "url-test",
        url: "http://www.gstatic.com/generate_204",
        interval: 300,   // 缩短测速时间至 5 分钟，让它更快自我恢复
        tolerance: 50,   // 设定容差，Ping 值相差 50ms 以内不随意横跳，真正的防横跳
        lazy: true,      // 省电核心
        hidden: true, 
        proxies: targetProxies
      });
      createdGroupNames.add(autoFailoverName);

      // Layer 2. 手动选择层 (用户界面)
      const finalName = icon ? `${icon} ${groupName}` : groupName;
      newProxyGroups.push({
        name: finalName,
        type: "select",
        // 将全局自动放在选择列表的第二位，作为 UI 层面的兜底
        proxies: [autoFailoverName, globalFallbackName, ...targetProxies]
      });
      createdGroupNames.add(finalName);

      return finalName;
    };

    // === 2. 处理 TaskList 生成策略组和规则 ===
    const taskRules = [];
    TaskList.forEach(task => {
      const keywordsUpper = task.keywords.map(k => k.toUpperCase());
      let matchedProxies = allValidProxies.filter(name => {
        const u = name.toUpperCase();
        return keywordsUpper.some(k => u.includes(k));
      });

      const finalGroupName = createAdvancedGroup(task.name, task.icon, matchedProxies);

      // 绑定域名规则
      task.domains.forEach(d => taskRules.push(`DOMAIN-SUFFIX,${d},${finalGroupName}`));
      // 绑定 IP 规则 (如 Telegram)
      task.ips.forEach(ip => taskRules.push(`IP-CIDR,${ip},${finalGroupName}`));
      task.ips.forEach(ip => taskRules.push(`IP-CIDR6,${ip},${finalGroupName}`));
      // 绑定进程规则 (如 Claude 客户端)
      task.processNames.forEach(p => taskRules.push(`PROCESS-NAME,${p},${finalGroupName}`));
    });

    // === 3. 组装最终规则集 ===
    
    // 特性：拦截 QUIC 防止 YouTube 降画质 (仅 Meta 核心生效)
    const QuicBlockRules = IS_CLASH_META ? [
      "AND,((DST-PORT,443),(NETWORK,UDP),(DOMAIN-KEYWORD,google)),REJECT",
      "AND,((DST-PORT,443),(NETWORK,UDP),(DOMAIN-KEYWORD,gvt)),REJECT"
    ] : [];

    const processDirectRules = [
      "PROCESS-NAME,WeChat.exe,DIRECT",
      "PROCESS-NAME,WeChatInput.exe,DIRECT",
      "PROCESS-NAME,WeChatResource.exe,DIRECT",
      "PROCESS-NAME,WeChat,DIRECT",
      "PROCESS-NAME,WeChatInput,DIRECT",
      "PROCESS-NAME,WeChatAppEx,DIRECT"
    ];

    const lanRules = [
      "IP-CIDR,192.168.0.0/16,DIRECT,no-resolve",
      "IP-CIDR,10.0.0.0/8,DIRECT,no-resolve",
      "IP-CIDR,172.16.0.0/12,DIRECT,no-resolve",
      "IP-CIDR,127.0.0.0/8,DIRECT,no-resolve"
    ];

    const directRules = DirectList.map(d => `DOMAIN-SUFFIX,${d.trim().toLowerCase()},DIRECT`);

    // === 4. 替换原配置 ===
    // 插入拦截组供 QUIC 使用
    newProxyGroups.push({ name: "🛑 拦截", type: "select", proxies: ["REJECT"] });

    // 清洗并合并旧的分组
    if (!config["proxy-groups"]) config["proxy-groups"] = [];
    config["proxy-groups"] = config["proxy-groups"].filter(
      oldGroup => !createdGroupNames.has(oldGroup.name) && oldGroup.name !== "🛑 拦截"
    );
    config["proxy-groups"].unshift(...newProxyGroups);

    // 合并规则
    config.rules = [
      ...QuicBlockRules,
      ...processDirectRules,
      ...lanRules,
      ...directRules,
      ...taskRules,
      ...(config.rules || [])
    ];

    console.log("🎉 脚本执行成功：双端融合版本已加载！已修复测速误判问题，开启防抖与省电模式。");
    return config;

  } catch (e) {
    console.error("❌ 脚本错误:", e);
    return config;
  }
};
