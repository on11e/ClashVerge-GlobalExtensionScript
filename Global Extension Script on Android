  {
    name: "AI与搜索", // 统一命名格式
    icon: "🤖",
    // 关键词：保留高质量地区筛选，融合了两端的关键字
    keywords: ["新加坡", "Singapore", "SG", "🇸🇬", "日本", "Japan", "JP", "🇯🇵", "韩国", "Korea", "KR", "🇰🇷", "美国", "States", "🇺🇸", "台湾", "TW", "Taiwan"],
