// ================= 配置区域 (Configuration) =================

// 1. 核心运行参数 (融合手机端优秀特性)
const MAX_PEERS = 80; // 限制测速节点上限，极大节省手机电量和 CPU 性能
const BlockWords = /流量|官网|网址|到期|重置|过期|通知|群组?|QQ|TG|subscription|aff|专线/i;

// 2. 自定义分组任务 (TaskList)
