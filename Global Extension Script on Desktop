    // 关键词：严格限制为香港节点
    keywords: [
      "香港", "Hong Kong", "HK", "HKG", "🇭🇰"
    ],
    domains: [
      // === YouTube ===
      "youtube.com", "youtu.be", "youtube-nocookie.com",
      "googlevideo.com", "ytimg.com", "ggpht.com", "gvt1.com",
      // === Twitter / X ===
      "twitter.com", "x.com", "t.co", "twimg.com",
      // === Telegram ===
      "telegram.org", "t.me", "telegram.me", "tx.me"
    ]
  }
];

// 🛑 黑名单：防止误杀
const BlockWords = [
  /流量|官网|网址|到期|重置/i,
  /通知|群组?|QQ|TG/i,
  /过期|剩余|expire/i
];

// 🏠 直连白名单 (Whitelist Mode)
const DirectList = [
  "servicewechat.com", "qpic.cn", "qlogo.cn", "gtimg.com", "idqqimg.com", "cdn-go.cn",
  "wechatos.net", "weixinbridge.com",
  "bit.cn", "bit.edu.cn", "bitzh.edu.cn",
  "baidu.com", "sogou.com", "so.com", "cn.bing.com",
  "163.com", "126.net", "sina.com.cn", "sohu.com", "qq.com",
  "taobao.com", "tmall.com", "jd.com", "pinduoduo.com",
  "alipay.com", "meituan.com", "dianping.com", "suning.com",
  "bilibili.com", "iqiyi.com", "youku.com", "mgtv.com", "douyin.com",
  "kuaishou.com", "yy.com", "huya.com", "douyu.com",
  "weibo.com", "weibo.cn", "zhihu.com", "xiaohongshu.com",
  "tieba.baidu.com", "wechat.com", "weixin.com",
  "aliyun.com", "tencent.com", "huawei.com", "mi.com", "vivo.com", "oppo.com",
  "360.cn", "360safe.com", "chinaz.com", "csdn.net",
  "apple.com.cn", "icloud.com.cn", "dbankcdn.com"
];

// ================= 核心逻辑 (Core Logic) =================
function main(config) {
  try {
    // 1. 提取并清洗节点
    const rawProxies = (config.proxies || []).map(p => {
      if (!p) return null;
      if (typeof p === 'string') return p;
      return p.name || p.id || null;
    }).filter(Boolean);

    // 过滤掉黑名单节点，得到所有可用节点
    const allValidProxies = rawProxies.filter(name => {
      return !BlockWords.some(r => r.test(name));
    });

    // 2. 预处理规则
    const processDirectRules = [
      "PROCESS-NAME,WeChat.exe,DIRECT",
      "PROCESS-NAME,WeChatInput.exe,DIRECT",
      "PROCESS-NAME,WeChatResource.exe,DIRECT",
      "PROCESS-NAME,WeChat,DIRECT",
      "PROCESS-NAME,WeChatInput,DIRECT",
      "PROCESS-NAME,WeChatAppEx,DIRECT"
    ];

    const lanRules = [
      "IP-CIDR,192.168.0.0/16,DIRECT,no-resolve",
      "IP-CIDR,10.0.0.0/8,DIRECT,no-resolve",
      "IP-CIDR,172.16.0.0/12,DIRECT,no-resolve",
      "IP-CIDR,127.0.0.0/8,DIRECT,no-resolve"
    ];

    const directRules = DirectList.map(d => `DOMAIN-SUFFIX,${d.trim().toLowerCase()},DIRECT`);

    const aiRules = [];
    const newProxyGroups = [];
    const createdGroupNames = new Set();

    // === 新增逻辑：创建全局兜底自动组 ===
    const globalFallbackName = "🚀 全局自动";
    const globalFallbackGroup = {
      name: globalFallbackName,
      type: "url-test",
      url: "http://www.gstatic.com/generate_204",
      // 修改点：86400秒 = 24小时
      interval: 86400, 
      tolerance: 150,
      lazy: true,
      proxies: allValidProxies.length > 0 ? allValidProxies : ["DIRECT"]
    };
    newProxyGroups.push(globalFallbackGroup);
    createdGroupNames.add(globalFallbackName);

    // 3. 任务处理循环
    TaskList.forEach(task => {
      // 3.1 筛选节点
      const keywordsUpper = task.keywords.map(k => k.toUpperCase());

      let matchedProxies = allValidProxies.filter(name => {
        const nameUpper = name.toUpperCase();
        return keywordsUpper.some(k => nameUpper.includes(k));
      });
      matchedProxies = [...new Set(matchedProxies)];

      // 3.2 构建策略组
      let finalGroupForRules = "";

      if (matchedProxies.length > 0) {
        // 情况 A：找到了特定节点
        const autoGroupName = `⚙️ ${task.name}-自动`;
        const autoGroup = {
          name: autoGroupName,
          type: "url-test",
          url: "http://www.gstatic.com/generate_204",
          interval: 600, // 针对特定地区的自动组，保持10分钟测速，保证该地区节点故障时能快速切换
          tolerance: 150,
          lazy: true,
          proxies: matchedProxies
        };
        newProxyGroups.push(autoGroup);
        createdGroupNames.add(autoGroupName);

        const manualGroupName = `${task.icon} ${task.name}`;
        const manualGroup = {
          name: manualGroupName,
          type: "select",
          proxies: [autoGroupName, ...matchedProxies, globalFallbackName]
        };
        newProxyGroups.push(manualGroup);
        createdGroupNames.add(manualGroupName);

        finalGroupForRules = manualGroupName;

      } else {
        // 情况 B：没找到特定节点，回退到全局自动
        console.log(`[${task.name}] ⚠️ 未找到匹配节点，回退到 ${globalFallbackName}`);
        
        const fallbackGroupName = `${task.icon} ${task.name}`;
        const fallbackGroup = {
          name: fallbackGroupName,
          type: "select",
          proxies: [globalFallbackName] 
        };
        newProxyGroups.push(fallbackGroup);
        createdGroupNames.add(fallbackGroupName);
        finalGroupForRules = fallbackGroupName;
      }

      // 3.3 构建域名规则
      task.domains.forEach(rawDomain => {
        const domain = rawDomain.trim().toLowerCase();
        aiRules.push(`DOMAIN-SUFFIX,${domain},${finalGroupForRules}`);
      });
    });

    // 4. 注入配置 
    const existingGroups = (config["proxy-groups"] || []).filter(g => !createdGroupNames.has(g.name));
    config["proxy-groups"] = [...newProxyGroups, ...existingGroups];

    const allNewRules = [
      ...processDirectRules,
      ...lanRules,
      ...aiRules,
      ...directRules
    ];

    config.rules = [...allNewRules, ...(config.rules || [])];

    console.log(`🎉 脚本执行成功：全局自动测速间隔已设为24小时`);
    return config;

  } catch (e) {
    console.error("❌ 脚本执行出错，已返回原始配置:", e);
    return config;
  }
}
