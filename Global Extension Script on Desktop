// ================= 核心逻辑 (Core Logic) =================
function main(config) {
  try {
    // 1. 提取并清洗节点
    const rawProxies = (config.proxies || []).map(p => {
      if (!p) return null;
      if (typeof p === 'string') return p;
      return p.name || p.id || null;
    }).filter(Boolean);

    const allValidProxies = rawProxies.filter(name => !BlockWords.some(r => r.test(name)));

    if (allValidProxies.length === 0) {
      console.log("⚠️ 未找到有效节点，脚本跳过执行");
      return config;
    }

    const newProxyGroups = [];
    const createdGroupNames = new Set(); 

    // === 核心组件 1: 全局自动兜底 (Layer 0) ===
    const globalFallbackName = "🚀 全局自动";
    newProxyGroups.push({
      name: globalFallbackName,
      type: "url-test",
      url: "http://www.gstatic.com/generate_204",
      interval: 86400, // 24小时测一次
      tolerance: 150,
      lazy: true,
      // ⚠️ 修改点：这里去掉了 hidden: true，让它显示出来
      proxies: allValidProxies
    });
    createdGroupNames.add(globalFallbackName);

    // === 核心组件 2: 高级分组生成器 ===
    function createAdvancedGroup(groupName, icon, proxiesList) {
      // 1. 纯净测速组 (Layer 1)
      const speedTestName = `⚡ ${groupName}-测速`;
      newProxyGroups.push({
        name: speedTestName,
        type: "url-test",
        url: "http://www.gstatic.com/generate_204",
        interval: 600,
        tolerance: 150,
        lazy: true,
        hidden: true, // 🙈【隐藏】后台测速逻辑，不显示
        proxies: proxiesList
      });
      createdGroupNames.add(speedTestName);

      // 2. 故障转移组 (Layer 2)
      const autoFailoverName = `⚙️ ${groupName}-自动`;
      newProxyGroups.push({
        name: autoFailoverName,
        type: "fallback",
        url: "http://www.gstatic.com/generate_204",
        interval: 600,
        hidden: true, // 🙈【隐藏】后台故障切换逻辑，不显示
        proxies: [speedTestName, globalFallbackName]
      });
      createdGroupNames.add(autoFailoverName);

      // 3. 手动选择层 (Layer 3 - 用户界面)
      const finalName = icon ? `${icon} ${groupName}` : groupName;
      newProxyGroups.push({
        name: finalName,
        type: "select",
        // 这里没有 hidden，显示给用户看
        proxies: [autoFailoverName, globalFallbackName, ...proxiesList]
      });
      createdGroupNames.add(finalName);

      return finalName;
    }

    // 2. 处理 TaskList
    const taskRules = [];
    TaskList.forEach(task => {
      const keywordsUpper = task.keywords.map(k => k.toUpperCase());
      let matchedProxies = allValidProxies.filter(name => {
        const u = name.toUpperCase();
        return keywordsUpper.some(k => u.includes(k));
      });
      matchedProxies = [...new Set(matchedProxies)];

      let finalGroupName = "";
      if (matchedProxies.length > 0) {
        finalGroupName = createAdvancedGroup(task.name, task.icon, matchedProxies);
      } else {
        // 无节点直接回退
        console.log(`[${task.name}] ⚠️ 无节点，回退到全局`);
        finalGroupName = `${task.icon} ${task.name}`;
        newProxyGroups.push({
          name: finalGroupName,
          type: "select",
          proxies: [globalFallbackName]
        });
        createdGroupNames.add(finalGroupName);
      }

      task.domains.forEach(d => {
        taskRules.push(`DOMAIN-SUFFIX,${d},${finalGroupName}`);
      });
    });

    // 3. 原地升级现有分组
    const existingGroups = config["proxy-groups"] || [];
    existingGroups.forEach(group => {
      if (createdGroupNames.has(group.name)) return;
      if (["select", "url-test", "fallback"].includes(group.type) && group.proxies && group.proxies.length > 0) {
        createAdvancedGroup(group.name, null, group.proxies);
      } else {
        newProxyGroups.push(group);
      }
    });

    // 4. 组装规则
    const processDirectRules = [
      "PROCESS-NAME,WeChat.exe,DIRECT",
      "PROCESS-NAME,WeChatInput.exe,DIRECT",
      "PROCESS-NAME,WeChatResource.exe,DIRECT",
      "PROCESS-NAME,WeChat,DIRECT",
      "PROCESS-NAME,WeChatInput,DIRECT",
      "PROCESS-NAME,WeChatAppEx,DIRECT"
    ];
    const lanRules = [
      "IP-CIDR,192.168.0.0/16,DIRECT,no-resolve",
      "IP-CIDR,10.0.0.0/8,DIRECT,no-resolve",
      "IP-CIDR,172.16.0.0/12,DIRECT,no-resolve",
      "IP-CIDR,127.0.0.0/8,DIRECT,no-resolve"
    ];
    const directRules = DirectList.map(d => `DOMAIN-SUFFIX,${d.trim().toLowerCase()},DIRECT`);

    config.rules = [
      ...processDirectRules,
      ...lanRules,
      ...taskRules,
      ...directRules,
      ...(config.rules || [])
    ];

    config["proxy-groups"] = newProxyGroups;

    console.log("🎉 脚本执行成功：已显示全局自动，隐藏中间逻辑组");
    return config;

  } catch (e) {
    console.error("❌ 脚本错误:", e);
    return config;
  }
}
